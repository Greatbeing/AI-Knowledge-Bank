    "id": "00000000-0000-0000-0000-000000000101",
    "title": "AI 场景拆解四层法",
    "node_type": "case",
    "weight": 92,
    "is_mainline": true,
    "is_emerging": false,
    "version_label": "AKB-K-001",
    "content": {
      "vault": "knowledge",
      "summary": "把一个模糊 AI 需求拆成目标、输入、约束、验证四层，避免直接从工具或 Prompt 开始。",
      "when_to_use": "用户只有一个想法，但还没有明确数据、流程、责任边界和验收指标。",
      "framework": ["目标层：用户真正要改善的结果", "输入层：可用数据、样例、权限和上下文", "约束层：成本、隐私、合规、人工确认点", "验证层：怎样证明 AI 输出有效"],
      "keywords": ["scenario mapping", "AI strategy", "goal input constraint validation", "知识库"]
    }
  },
  {
    "id": "00000000-0000-0000-0000-000000000102",
    "title": "Prompt 反幻觉边界原则",
    "node_type": "case",
    "weight": 88,
    "is_mainline": true,
    "is_emerging": false,
    "version_label": "AKB-K-002",
    "content": {
      "vault": "knowledge",
      "summary": "高风险 Prompt 必须声明未知处理、引用要求、人工复核点和禁止猜测范围。",
      "principles": ["无法确认时输出待核验，而不是补全细节", "事实结论必须带来源或可追溯证据", "把生成任务和判断任务拆开", "关键决策保留人工复核"],
      "failure_signals": ["引用不存在", "把建议写成事实", "跳过用户给出的限制条件"],
      "keywords": ["prompt safety", "anti hallucination", "verification", "知识库"]
    }
  },
  {
    "id": "00000000-0000-0000-0000-000000000103",
    "title": "RAG 入库质量标准",
    "node_type": "case",
    "weight": 90,
    "is_mainline": true,
    "is_emerging": false,
    "version_label": "AKB-K-003",
    "content": {
      "vault": "knowledge",
      "summary": "RAG 不是把文件塞进向量库，而是把可引用、可分段、可更新、可验证的知识变成检索资产。",
      "checklist": ["每段只表达一个稳定知识点", "保留来源、作者、时间和适用场景", "区分事实、经验、观点和模板", "为过期内容设置复审周期"],
      "quality_metric": "命中结果能否支持用户直接采取下一步行动。",
      "keywords": ["RAG", "knowledge ingestion", "source refs", "知识库"]
    }
  },
